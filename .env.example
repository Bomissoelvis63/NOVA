# Exemple de variables d'environnement pour NOVA.
# Il sert a configurer Django sans exposer de secrets dans le code.
# Il definit la base PostgreSQL utilisee par le serveur IAM.
# Il fixe les hotes et origines CORS autorises en developpement.
# Son but est de fournir un modele simple pour creer le fichier .env.
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_CREDENTIALS=True
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

SESSION_COOKIE_AGE=1209600
SESSION_COOKIE_SECURE=False
SESSION_COOKIE_SAMESITE=Lax
SESSION_SAVE_EVERY_REQUEST=False
CSRF_COOKIE_SECURE=False
CSRF_COOKIE_SAMESITE=Lax

POSTGRES_DB=nova
POSTGRES_USER=nova
POSTGRES_PASSWORD=nova
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
